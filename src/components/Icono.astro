---
// Set de íconos de línea coherente (trazo 1.5, outline, viewBox 24).
// Uso: <Icono nombre="render" />
interface Props {
  nombre: string;
  class?: string;
}
const { nombre, class: clase } = Astro.props;

const iconos: Record<string, string> = {
  // Diseño arquitectónico — escuadra de dibujo
  diseno: `<path d="M5 4v16h16z"/><path d="M5 9h2.2M5 13h2.2M5 17h2.2"/>`,
  // Visualización y renders 3D — volumen isométrico
  render: `<path d="M21 8 12 3 3 8v8l9 5 9-5Z"/><path d="M3 8l9 5 9-5"/><path d="M12 13v8"/>`,
  // Diseño de interiores — sillón
  interiores: `<path d="M19 9V6a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v3"/><path d="M3 11v5a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-5a2 2 0 0 0-4 0v2H7v-2a2 2 0 0 0-4 0Z"/><path d="M5 18v2M19 18v2"/>`,
  // Remodelación y ampliación — muro de ladrillo
  remodelacion: `<rect x="3" y="4" width="18" height="16" rx="1"/><path d="M3 9.3h18M3 14.6h18"/><path d="M10 4v5.3M16 9.3v5.3M8 14.6V20M14 14.6V20"/>`,
  // Dirección de obra — casco
  obra: `<path d="M3 18a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1v-1.5a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1Z"/><path d="M10 9.5V6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3.5"/><path d="M5 15.5v-3a6 6 0 0 1 5-5.9"/><path d="M14 6.6a6 6 0 0 1 5 5.9v3"/>`,
  // Asesoría y consultoría — compás de dibujo
  consultoria: `<circle cx="12" cy="5" r="1.6"/><path d="M11.2 6.4 6 20M12.8 6.4 18 20"/><path d="M9.3 13.4a5 5 0 0 0 5.4 0"/>`,
};

const contenido = iconos[nombre] ?? "";
---

<svg
  class={clase}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={contenido}
/>
